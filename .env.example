# ─── Supabase ────────────────────────────────────────────
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role (server-only — never expose to client)
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres connection (used by Drizzle migrations and sync-forms script)
# Project Settings → Database → Connection string → URI (use the Connection Pooler / Transaction mode for app, Session mode for migrations)
DATABASE_URL=postgresql://postgres:PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# ─── App ─────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Comma-separated emails granted admin role on first login
# (after first login the row exists in app_users and this fallback can be cleared)
ADMIN_EMAIL_ALLOWLIST=
